{
  "$schema": "https://jseverino.com/schemas/cordon-checks-config-v2.json",
  "commands": [
    {
      "id": "version",
      "name": "Version alignment",
      "effect": "read",
      "requires": ["python3"],
      "exec": { "cmd": "python3", "args": ["scripts/version_check.py"] },
      "fix": "Align pyproject.toml version with src/severino_vault_mcp/__init__.py __version__."
    },
    {
      "id": "doctor",
      "name": "Sample-vault doctor",
      "effect": "read",
      "requires": ["uv"],
      "exec": {
        "cmd": "sh",
        "args": ["-c", "PYTHONPATH=src SVMC_VAULT_PATH=examples/sample-vault uv run python -m severino_vault_mcp doctor"]
      },
      "fix": "Fix the frontmatter issues doctor reports in examples/sample-vault."
    }
  ]
}
